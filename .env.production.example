# ============================================================
# .env.production — Frontend Next.js (puerto 3006)
# ============================================================
# Copiar a .env.production y completar valores reales:
#   cp .env.production.example .env.production && nano .env.production
# NO commitear .env.production.

# ----- Backend NestJS (server-only, NO se filtra al bundle) -----
# El backend corre en el mismo servidor en el puerto 3001.
# Usamos localhost porque la conexión es server-to-server.
BACKEND_API_URL=http://localhost:3001

# ----- Cloudflare Turnstile -----
# Site key REAL de producción (público, se inyecta en el HTML).
# Asegurarse en https://dash.cloudflare.com/turnstile que el
# Hostname incluye "estadosdecuenta.amdc.hn".
NEXT_PUBLIC_TURNSTILE_SITE_KEY=0x4AAAAAADF494xbeho9A3Eg

# ----- Amnistía -----
# Debe coincidir con AMNISTIA_ACTIVA del backend (mer-fact-back/.env).
# Controla la badge "Amnistía vigente" en el hero y la alerta del landing.
NEXT_PUBLIC_AMNISTIA_ACTIVA=true
# Debe coincidir con AMNISTIA_FECHA_FIN del backend (YYYY-MM-DD).
# La alerta del landing se oculta automáticamente al pasar esta fecha
# (zona horaria Honduras, UTC-6).
NEXT_PUBLIC_AMNISTIA_FECHA_FIN=2026-05-13

# ----- Node -----
NODE_ENV=production
