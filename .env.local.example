# Backend NestJS (mer-fact-back)
NEXT_PUBLIC_API_BASE_URL=http://localhost:3009

# Cloudflare Turnstile - registrar site en https://dash.cloudflare.com → Turnstile
# Site key es público; Secret key va en el backend
#
# IMPORTANTE en desarrollo local:
# - Si usas tu site key real, agrega "localhost" a "Hostname management"
#   en el dashboard de Cloudflare Turnstile (de lo contrario verás
#   "Error: 110200" — domain not allowed).
# - O usa el site key de prueba "1x00000000000000000000AA" (siempre pasa)
#   junto con la secret de prueba "1x0000000000000000000000000000000AA"
#   en el backend (TURNSTILE_SECRET_KEY).
NEXT_PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA

# Coincide con backend AMNISTIA_ACTIVA — controla la badge "Amnistía vigente" en hero
NEXT_PUBLIC_AMNISTIA_ACTIVA=true
# Coincide con backend AMNISTIA_FECHA_FIN (YYYY-MM-DD). La alerta del landing
# se oculta automáticamente al pasar esta fecha (zona horaria Honduras, UTC-6).
NEXT_PUBLIC_AMNISTIA_FECHA_FIN=2026-05-13

NODE_ENV=development
